# Required for OpenAI (or set MOCK_MODE=1 to skip API)
OPENAI_API_KEY=your_openai_key_here

# Database: SQLite (local) or Postgres (cloud)
# Local:
DATABASE_URL=sqlite:///./smart_gtm.db
# Cloud (e.g. Railway, Render, Supabase): paste the Postgres URI they provide (scheme postgres or postgresql).

# Optional: use mock plans without calling OpenAI
# MOCK_MODE=0

# Optional: port when running in container (default 8000)
# PORT=8000
